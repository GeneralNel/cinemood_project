<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: '@' + profile.username + ' — Cinemood' }) %></head>
<body>
<%- include('partials/header') %>

<section class="profile-banner">
  <div class="profile-id">
    <div class="profile-avatar"><%= (profile.displayName || profile.username || '?').charAt(0).toUpperCase() %></div>
    <div class="who">
      <h1><%= profile.displayName || profile.username %></h1>
      <span class="handle">@<%= profile.username %></span>
      <span class="stats"><%= boards.length %> public board<%= boards.length === 1 ? '' : 's' %></span>
      <% if (profile.bio) { %><p style="margin:0;color:rgba(255,248,225,.75);max-width:48rem"><%= profile.bio %></p><% } %>
    </div>
    <% if (isSelf) { %>
      <div class="own-actions">
        <a class="btn btn-mag" href="/create">Compose</a>
        <a class="btn btn-ghost" href="/settings">Settings</a>
      </div>
    <% } %>
  </div>
</section>

<main class="app-shell">
  <% if (boards && boards.length) { %>
    <div class="masonry">
      <% boards.forEach(b => { %>
        <%- include('partials/pin', { board: b, showVis: false }) %>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-note">
      <p class="hand">@<%= profile.username %> hasn't taped a public board yet.</p>
      <% if (isSelf) { %>
        <p><a class="btn btn-solid" href="/create">Compose your first board</a></p>
      <% } %>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
</body>
</html>
