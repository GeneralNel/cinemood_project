<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Cinemood — mood boards for movies' }) %></head>
<body>
<%- include('partials/header', { q: q }) %>

<main class="app-shell">

  <% if (q) { %>
    <div class="bucket-strip">
      <span class="dot"></span>
      <p class="greet">movies &amp; series for <strong>"<%= q %>"</strong> · <em><%= films.length %> result<%= films.length === 1 ? '' : 's' %></em></p>
      <a class="action-link" href="/">clear search</a>
    </div>
  <% } else if (boardQ) { %>
    <div class="bucket-strip">
      <span class="dot"></span>
      <p class="greet">boards matching <strong>"<%= boardQ %>"</strong> · <em><%= tonight.length %> tape<%= tonight.length === 1 ? '' : 's' %></em></p>
      <a class="action-link" href="/">clear</a>
    </div>
  <% } else { %>
    <div class="bucket-strip">
      <span class="dot"></span>
      <p class="greet">
        <% if (user) { %>
          hey <strong>@<%= user.username %></strong> — it's <em><%= bucketLabel %></em>, here's what fits the hour.
        <% } else { %>
          it's <em><%= bucketLabel %></em> somewhere — these mixtapes fit the hour.
        <% } %>
      </p>
      <details class="browse-boards">
        <summary>Browse boards</summary>
        <form method="get" action="/" role="search">
          <input type="search" name="board_q" placeholder="title, mood, or slug…" maxlength="80" autofocus>
          <button class="btn btn-sm btn-mag" type="submit">Find</button>
        </form>
      </details>
    </div>

    <% if (moodChips && moodChips.length) { %>
      <div class="rail-shell">
        <nav class="mood-chips" data-rail aria-label="Browse by mood">
          <% moodChips.forEach(c => { %>
            <a href="/?mood=<%= c.id %>" class="<%= activeMood === c.id ? 'on' : '' %>"><%= c.label %></a>
          <% }) %>
        </nav>
      </div>
    <% } %>
  <% } %>

  <% if (q && films.length) { %>
    <div class="rail-shell">
      <div class="film-strip" data-rail>
        <% films.forEach(f => { %>
          <div class="film">
            <div class="poster"><% if (f.poster) { %><img src="<%= f.poster %>" alt="" loading="lazy"><% } %></div>
            <div class="meta">
              <span class="title"><%= f.title %></span>
              <span class="year"><%= f.year || '' %><% if (f.kind === 'tv') { %> · series<% } %></span>
            </div>
            <% if (user) { %>
              <button class="save" type="button"
                data-watch-add="<%= f.tmdbId %>"
                data-title="<%= f.title %>"
                data-year="<%= f.year || '' %>"
                data-poster="<%= f.poster || '' %>"
                aria-label="save to watchlist">♡</button>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <% if (user && !q && !boardQ) { %>
    <%- include('partials/watchlist-rail', { watchlist }) %>
  <% } %>

  <% if (user && shelf.length && !q && !boardQ) { %>
    <div class="section-head">
      <h2>Your shelf</h2>
      <a class="more" href="/u/<%= user.username %>">view all →</a>
    </div>
    <div class="masonry">
      <a class="cta-pin" href="/create"><span class="plus">+</span>start a new board</a>
      <% shelf.forEach(b => { %>
        <%- include('partials/pin', { board: b, showVis: true }) %>
      <% }) %>
    </div>
  <% } %>

  <% if (tonight.length && !q) { %>
    <div class="section-head">
      <h2><%= boardQ ? 'Boards found' : "Tonight's wall" %></h2>
      <% if (!boardQ) { %><span class="blurb">tuned to <%= bucketLabel %></span><% } %>
    </div>
    <div class="masonry">
      <% tonight.forEach(b => { %>
        <%- include('partials/pin', { board: b, showVis: false }) %>
      <% }) %>
    </div>
  <% } %>

  <% if (fresh.length && !q && !boardQ) { %>
    <div class="section-head">
      <h2>Fresh from the wall</h2>
      <span class="blurb">just taped</span>
    </div>
    <div class="masonry">
      <% fresh.forEach(b => { %>
        <%- include('partials/pin', { board: b, showVis: false }) %>
      <% }) %>
    </div>
  <% } %>

  <% if (q && !films.length) { %>
    <div class="empty-note">
      <p class="hand">no movies or series match "<%= q %>" — try another word.</p>
    </div>
  <% } else if (boardQ && !tonight.length) { %>
    <div class="empty-note">
      <p class="hand">no tapes match "<%= boardQ %>" — try a mood or slug.</p>
    </div>
  <% } else if (!tonight.length && !fresh.length && !shelf.length && !q && !boardQ) { %>
    <div class="empty-note">
      <p class="hand">nothing on the wall yet — be the first to tape one up.</p>
      <p>
        <% if (user) { %>
          <a class="btn btn-solid" href="/create">Compose a board</a>
        <% } else { %>
          <a class="btn btn-solid" href="/signup">Sign up to compose</a>
        <% } %>
      </p>
    </div>
  <% } %>

</main>

<div class="toast-wrap" id="toastWrap" aria-live="polite"></div>

<%- include('partials/footer') %>
<script type="module" src="/js/watchlist.js"></script>
<script type="module" src="/js/rails.js"></script>
</body>
</html>
