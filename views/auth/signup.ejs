<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Sign up — Cinemood' }) %></head>
<body>
<%- include('../partials/header') %>

<main class="wrap auth-page">
  <section class="auth-card">
    <span class="kicker">welcome, new tape</span>
    <h2>Make a board</h2>
    <% if (errors && errors.length) { %>
      <ul class="errors">
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    <% } %>
    <form method="post" action="/signup" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="field">
        <label for="username">username</label>
        <input id="username" name="username" required minlength="2" maxlength="24"
               value="<%= form.username || '' %>" autocomplete="username">
        <span class="hint">lowercase letters, numbers, underscore</span>
      </div>
      <div class="field">
        <label for="displayName">display name</label>
        <input id="displayName" name="displayName" maxlength="60"
               value="<%= form.displayName || '' %>">
        <span class="hint">how your boards sign off</span>
      </div>
      <div class="field">
        <label for="email">email</label>
        <input id="email" name="email" type="email" required
               value="<%= form.email || '' %>" autocomplete="email">
      </div>
      <div class="field">
        <label for="password">password</label>
        <input id="password" name="password" type="password" required minlength="8"
               autocomplete="new-password">
        <span class="hint">8+ characters. keep it weird.</span>
      </div>
      <div class="actions">
        <button class="btn btn-solid btn-block" type="submit">Start the tape</button>
      </div>
      <p class="alt">already got one? <a href="/login">sign in</a></p>
    </form>
  </section>
</main>

<%- include('../partials/footer') %>
</body>
</html>
