<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Your boards — Cinemood' }) %></head>
<body>
<%- include('partials/header') %>

<main class="wrap section">
  <header class="dash-head">
    <div>
      <span class="eyebrow">your shelf</span>
      <h1>Hey, <%= user.displayName || user.username %></h1>
      <p class="who">@<%= user.username %></p>
    </div>
    <a class="btn btn-solid" href="/create">Compose a board</a>
  </header>

  <% if (boards && boards.length) { %>
    <section class="grid">
      <% boards.forEach(b => { %>
        <a class="board-card" href="/board/<%= b.slug %>/edit">
          <span class="label"><%= b.title %></span>
          <div class="mosaic">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="tile">
                <% if (b.cover && b.cover[i]) { %>
                  <img src="<%= b.cover[i] %>" alt="">
                <% } %>
              </div>
            <% } %>
          </div>
          <div class="tags">
            <% (b.moodTags || []).slice(0, 3).forEach(t => { %><span class="tag"><%= t %></span><% }) %>
          </div>
          <div class="meta">
            <span><%= new Date(b.updatedAt).toLocaleDateString() %></span>
            <span class="vis <%= b.visibility %>"><%= b.visibility %></span>
          </div>
        </a>
      <% }) %>
    </section>
  <% } else { %>
    <div class="dash-empty">
      <p class="hand">nothing here yet — make your first tape.</p>
      <p><a class="btn btn-solid" href="/create">Compose a board</a></p>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>
</body>
</html>
