<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="/">
      <span class="dot"></span><span class="word">CINEMOOD</span>
    </a>

    <form class="topbar-search" action="/" method="get" role="search">
      <input type="search" name="q" placeholder="search movies &amp; series…" value="<%= typeof q !== 'undefined' && q ? q : '' %>" maxlength="80" aria-label="Search movies and series">
      <button type="submit" aria-label="Search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
    </form>

    <nav class="topbar-actions">
      <% if (user) { %>
        <a class="action-link <%= path === '/create' ? 'active' : '' %>" href="/create">Compose</a>
        <details class="user-menu">
          <summary aria-label="Your account">
            <span class="avatar"><%= (user.displayName || user.username || '?').charAt(0).toUpperCase() %></span>
            <span class="who-name"><%= user.displayName || user.username %></span>
          </summary>
          <div class="menu-pop">
            <a href="/u/<%= user.username %>">Your shelf</a>
            <a href="/create">Compose a board</a>
            <a href="/settings">Settings</a>
            <form method="post" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit">Log out</button>
            </form>
          </div>
        </details>
      <% } else { %>
        <a class="action-link" href="/login">Log in</a>
        <a class="btn btn-sm btn-mag" href="/signup">Sign up</a>
      <% } %>
    </nav>
  </div>
</header>
<div class="tracking" id="tracking"></div>
